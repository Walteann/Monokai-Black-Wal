	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"fontStyle": "italic",
				"foreground": "#546E7A"
			}
		},
		{
			"name": "Variables",
			"scope": [
				"variable",
				"string constant.other.placeholder",
			],
			"settings": {
				"foreground": "#678CB1"
			}
		},
		{
			"name": "Colors",
			"scope": [
				"constant.other.color"
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#FF5370"
			}
		},
		{
			"name": "Keyword, Storage",
			"scope": [
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#66d9ef",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Variables Dart",
			"scope": [
				"variable.parameter.dart"
			],
			"settings": {
				"foreground": "#74E6DB",
			}
		},
		{
			"name": "Function dart",
			"scope": [
				"entity.name.function.dart"
			],
			"settings": {
				"foreground": "#2EA6E2",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Operator, Misc",
			"scope": [
				"punctuation",
				"meta.tag",
				"punctuation.definition.tag",
				"punctuation.separator.inheritance.php",
				"punctuation.definition.tag.html",
				"punctuation.definition.tag.begin.html",
				"punctuation.definition.tag.end.html",
				"punctuation.section.embedded",
				"keyword.other.template",
				"keyword.other.substitution"
			],
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"name": "Keywords #f92672",
			"scope": [
				"keyword.control.import.ts",
				"keyword.control.export.ts",
				"keyword.other.import.dart",
				"keyword.declaration.dart",
				"storage.modifier.ts",
				"keyword.control",
				"keyword.operator",
				"source.ini",
				"keyword.other.special-method.dockerfile"
				
			],
			"settings": {
				"foreground": "#f92672"
			}
		},
		{
			"name": "Keywords #f92672 and italic",
			"scope": [
				"keyword.control.from",
				
			],
			"settings": {
				"foreground": "#f92672",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords reserved",
			"scope": [
				"variable.parameter",
				"entity.other.attribute-name.id",
				"entity.other.attribute-name.id.css"
			],
			"settings": {
				"foreground": "#FD971F",
				"fontStyle": "italic",
			}
		},
		{
			"name": "Keywords #FFF",
			"scope": [
				"variable.object.property.ts"
			],
			"settings": {
				"foreground": "#f6f9ff",
				"fontStyle": "italic",
			}
		},
		{
			"name": "Keywords #FFF and italic",
			"scope": [
				"punctuation.definition.keyword.scss"
			],
			"settings": {
				"foreground": "#FFF",
				"fontStyle": "italic",
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"meta.tag.sgml",
				"markup.deleted.git_gutter",
			],
			"settings": {
				"foreground": "#f92672"
			}
		},
		{
			"name": "Function, Special Method",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"variable.function",
				"support.function",
				"keyword.other.special-method",
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#a6e22e"
			}
		},
		{
			"name": "Block Level Variables",
			"scope": [
				"meta.block variable.other",
			],
			"settings": {
				"foreground": "#678CB1"
			}
		},
		{
			"name": "Other Variable, String Link",
			"scope": [
				"support.other.variable",
				"string.other.link"
			],
			"settings": {
				"foreground": "#f07178"
			}
		},
		{
			"name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character",
				"constant.escape",
				"keyword.other.unit",
				"keyword.other",
			],
			"settings": {
				"foreground": "#ae81ff"
			}
		},
		{
			"name": "Constants",
			"scope": [
				"support.constant",
				"variable.other.constant"
			],
			"settings": {
				"foreground": "#2a8ee0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Const declaration identifier",
			"scope": [
				"variable.other.readwrite.alias",
				"variable.other.readwrite.alias.ts",
				"variable.other.readwrite.alias.tsx"
			],
			"settings": {
				"foreground": "#678CB1",
				"fontStyle": "bold"
			}
		},
		{
			"name": "String, Symbols, Inherited Class, Markup Heading",
			"scope": [
				"string",
				"constant.other.symbol",
				"constant.other.key",
				"markup.heading",
				"markup.inserted.git_gutter",
				"meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js",
				"identifier.unquoted.plain.out.yaml",
				"identifier.quoted.single.yaml",
				"punctuation.definition.string.begin",
				"punctuation.definition.string.end",
				"identifier.quoted.double.yaml",
