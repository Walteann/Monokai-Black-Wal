		"variable":       "#678CB1",
		"property":       "#64B5F6",
		"enumMember":     "#ae81ff",
		"event":          "#f07178",
		"function":       "#a6e22e",
		"method":         "#a6e22e",
		"macro":          "#f92672",
		"keyword":        "#f92672",
		"modifier":       { "foreground": "#66d9ef", "fontStyle": "italic" },
		"comment":        { "foreground": "#546E7A", "fontStyle": "italic" },
		"string":         "#e6db74",
		"number":         "#ae81ff",
		"regexp":         "#89DDFF",
		"operator":       "#FFFFFF",
		"decorator":      { "foreground": "#82AAFF", "fontStyle": "italic" },
		// declaration — bold só onde faz sentido
		"function.declaration":  { "fontStyle": "bold" },
		"method.declaration":    { "fontStyle": "bold" },
		"class.declaration":     { "fontStyle": "bold" },

		// readonly — propriedades e variáveis separadas
		"property.readonly":             { "foreground": "#42A5F5", "fontStyle": "italic" },
		"property.readonly.declaration": { "foreground": "#eeffff", "fontStyle": "italic" },
		"variable.readonly":             { "foreground": "#42A5F5", "fontStyle": "italic" },

		// static — só métodos e propriedades
		"method.static":   { "fontStyle": "italic" },
		"property.static": { "fontStyle": "italic" },

		// deprecated — todos os tipos relevantes
		"variable.deprecated":  { "fontStyle": "strikethrough" },
		"function.deprecated":  { "fontStyle": "strikethrough" },
		"method.deprecated":    { "fontStyle": "strikethrough" },
		"property.deprecated":  { "fontStyle": "strikethrough" },
		"class.deprecated":     { "fontStyle": "strikethrough" },

		// abstract — só classes e métodos
		"class.abstract":  { "fontStyle": "italic" },
		"method.abstract": { "fontStyle": "italic" },

		// async — só funções e métodos
		"function.async": { "foreground": "#82AAFF", "fontStyle": "italic" },
		"method.async":   { "foreground": "#82AAFF", "fontStyle": "italic" },

		// documentation — comentários JSDoc
		"comment.documentation": { "foreground": "#546E7A", "fontStyle": "italic" },

		// defaultLibrary — built-ins da stdlib por tipo
